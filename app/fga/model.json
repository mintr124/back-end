{
  "schema_version": "1.1",
  "type_definitions": [
    { "type": "user", "relations": {} },

    {
      "type": "oui",
      "relations": {
        "member": { "this": {} },
        "parent_oui": { "this": {} },
        "ancestor_member": {
          "union": {
            "child": [
              { "computedUserset": { "relation": "member" } },
              {
                "tupleToUserset": {
                  "tupleset": { "relation": "parent_oui" },
                  "computedUserset": { "relation": "ancestor_member" }
                }
              }
            ]
          }
        }
      },
      "metadata": {
        "relations": {
          "member": { "directly_related_user_types": [{ "type": "user" }] },
          "parent_oui": { "directly_related_user_types": [{ "type": "oui" }] },
          "ancestor_member": { "directly_related_user_types": [] }
        }
      }
    },

    {
      "type": "document",
      "relations": {
        "owner": { "this": {} },

        "viewer": { "this": {} },

        "editor": { "this": {} },

        "can_view": {
          "union": {
            "child": [
              { "computedUserset": { "relation": "owner" } },
              { "computedUserset": { "relation": "editor" } },
              { "computedUserset": { "relation": "viewer" } }
            ]
          }
        },

        "can_edit": {
          "union": {
            "child": [
              { "computedUserset": { "relation": "owner" } },
              { "computedUserset": { "relation": "editor" } }
            ]
          }
        }
      },
      "metadata": {
        "relations": {
          "owner": {
            "directly_related_user_types": [{ "type": "user" }]
          },
          "viewer": {
            "directly_related_user_types": [
              { "type": "user" },
              { "type": "oui", "relation": "member", "condition": "clearance_sufficient" },
              { "type": "oui", "relation": "ancestor_member", "condition": "clearance_sufficient" }
            ]
          },
          "editor": {
            "directly_related_user_types": [
              { "type": "user" },
              { "type": "oui", "relation": "member", "condition": "clearance_sufficient" }
            ]
          },
          "can_view": { "directly_related_user_types": [] },
          "can_edit": { "directly_related_user_types": [] }
        }
      }
    }
  ],
  "conditions": {
    "clearance_sufficient": {
      "name": "clearance_sufficient",
      "expression": "user_clearance >= required_clearance",
      "parameters": {
        "user_clearance": { "type_name": "TYPE_NAME_INT" },
        "required_clearance": { "type_name": "TYPE_NAME_INT" }
      }
    }
  }
}
