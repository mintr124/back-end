        {
          "rule_id": "R-FIN03-02",
          "name": "Cấm AI tóm tắt thông tin quỹ ra ngoài hệ thống nội bộ",
          "applicable_intents": [
            "summarize",
            "export"
          ],
          "risk_level": "very_high",
          "action": "DENY",
          "priority": 95,
          "mandatory": true
        }
      ]
    },
