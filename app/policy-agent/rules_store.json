        {
          "rule_id": "R-HR01-02",
          "name": "HR full access có audit log",
          "applicable_roles": [
            "HR"
          ],
          "risk_level": "medium",
          "action": "ALLOW",
          "priority": 60,
          "mandatory": false,
          "audit_log": true
