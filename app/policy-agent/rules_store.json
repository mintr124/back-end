{
  "rule_sets": {
    "FIN-01": {
      "name": "Báo cáo tài chính / Kế toán",
      "base_sensitivity": "Confidential",
      "rules": [
        {
          "rule_id": "R-FIN01-01",
          "name": "Cấm export báo cáo tài chính chưa công bố",
          "min_sensitivity": "Confidential",
          "applicable_roles": [
            "Employee",
            "Manager",
            "Director"
          ],
          "blocked_roles": [
            "External",
            "Intern"
          ],
          "min_user_level": 3,
          "applicable_intents": [
            "export",
            "aggregate"
          ],
          "risk_level": "high",
          "action": "DENY",
          "priority": 80,
          "mandatory": false
        },
        {
          "rule_id": "R-FIN01-02",
          "name": "Cho phép xem nội bộ với watermark",
          "min_sensitivity": "Internal",
          "applicable_roles": [
            "Employee",
            "Manager",
            "Director"
          ],
          "min_user_level": 1,
          "applicable_intents": [
            "lookup",
            "summarize"
          ],
          "risk_level": "medium",
          "action": "ALLOW_WITH_WATERMARK",
          "priority": 50,
          "mandatory": false
        },
        {
          "rule_id": "R-FIN01-03",
          "name": "Auditor được đọc, không export",
          "applicable_roles": [
            "Auditor"
          ],
          "min_user_level": 2,
          "applicable_intents": [
            "lookup",
            "compare"
          ],
          "risk_level": "medium",
          "action": "ALLOW",
          "priority": 60,
          "mandatory": false,
          "audit_log": true
        }
      ]
    },
    "FIN-02": {
      "name": "Ngân sách & Chi tiêu",
      "base_sensitivity": "Internal",
      "rules": [
        {
          "rule_id": "R-FIN02-01",
          "name": "Redact số liệu ngân sách cross-department",
          "min_sensitivity": "Internal",
          "applicable_roles": [
            "Employee",
            "Manager"
          ],
          "cross_dept_only": true,
          "risk_level": "medium",
          "action": "REDACT",
          "priority": 55,
          "mandatory": false,
          "redaction_fields": [
            "amount",
            "budget_line"
          ]
        },
        {
          "rule_id": "R-FIN02-02",
          "name": "Finance team xem toàn bộ chi tiết",
          "applicable_roles": [
            "Manager",
            "Director"
          ],
          "require_department": "Finance",
          "risk_level": "low",
          "action": "ALLOW",
          "priority": 70,
          "mandatory": false
        }
      ]
    },
    "FIN-03": {
      "name": "Đầu tư / Quỹ",
      "base_sensitivity": "Restricted",
      "rules": [
        {
          "rule_id": "R-FIN03-01",
          "name": "Chỉ Director+ truy cập thông tin đầu tư",
          "min_sensitivity": "Restricted",
          "applicable_roles": [
            "Director",
            "BOD"
          ],
          "blocked_roles": [
            "Employee",
            "Manager",
            "External"
