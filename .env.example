### Database / infra
DATABASE_URL=mysql+pymysql://user:pass@mysql:3306/dbname
REDIS_URL=redis://redis:6379/0

### Gmail OAuth
# Local callback used by the development frontend.
GMAIL_REDIRECT_URI=http://localhost:8083/gmail/callback

### MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

### Chroma
CHROMA_PATH=/data/chroma
CHROMA_COLLECTION=document_chunks

### LLM (choose one provider or leave unset to disable)
# Set to 'openai' or 'olama'
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMS=768

# Olama
OLAMA_URL=http://host.docker.internal:11434
OLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM timeout
LLM_TIMEOUT_SECONDS=300
APP_NAME=rag-role-enterprise-api
ENV=dev

DATABASE_URL=mysql+pymysql://rag:rag@mysql:3306/ragdb?charset=utf8mb4
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

OPENFGA_URL=http://openfga:8080
OPENFGA_STORE_ID=     
OPENFGA_MODEL_ID=

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_PROCESSED=processed

CHROMA_PATH=/data/chroma
CHROMA_COLLECTION=document_chunks
EMBEDDING_DIMS=384
MAX_UPLOAD_SIZE_MB=50
DEFAULT_POLICY_VERSION=v1
