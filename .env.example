### Database / infra
DATABASE_URL=mysql+pymysql://user:pass@mysql:3306/dbname
REDIS_URL=redis://redis:6379/0

### MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

### Chroma
CHROMA_PATH=/data/chroma
CHROMA_COLLECTION=document_chunks

### LLM (choose one provider or leave unset to disable)
# Set to 'openai' or 'olama'
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMS=256

# Olama
OLAMA_URL=http://localhost:11434
OLAMA_MODEL=ggml-vicuna-13b

# LLM timeout
LLM_TIMEOUT_SECONDS=30
APP_NAME=rag-role-enterprise-api
ENV=dev

DATABASE_URL=mysql+pymysql://rag:rag@mysql:3306/ragdb?charset=utf8mb4
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_PROCESSED=processed

CHROMA_PATH=/data/chroma
CHROMA_COLLECTION=document_chunks
EMBEDDING_DIMS=384
MAX_UPLOAD_SIZE_MB=50
DEFAULT_POLICY_VERSION=v1
