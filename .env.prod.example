# Public API domain. Create an A record pointing this host to the EC2 Elastic IP.
API_DOMAIN=api.example.com

# Comma-separated browser origins allowed by FastAPI.
CORS_ORIGINS=https://main.roles-aware-rag.amplifyapp.com

APP_NAME=rag-role-enterprise-api
ENV=prod

# These values must match the MySQL service in docker-compose.prod.yml.
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=ragdb
MYSQL_USER=rag
MYSQL_PASSWORD=change-me-mysql
DATABASE_URL=mysql+pymysql://rag:change-me-mysql@mysql:3306/ragdb?charset=utf8mb4

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=1440

OPENFGA_URL=http://openfga:8080
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=
POSTGRES_FGA_USER=fga
POSTGRES_FGA_PASSWORD=change-me-fga
POSTGRES_FGA_DB=fga

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me-minio
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_PROCESSED=processed

CHROMA_PATH=/data/chroma
CHROMA_COLLECTION=document_chunks
CHROMA_HOST=chroma
CHROMA_PORT=8000

MAX_UPLOAD_SIZE_MB=50
DEFAULT_POLICY_VERSION=v1

# Use OpenAI on a CPU EC2 instance; do not use local Ollama unless it is hosted separately.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMS=1536
LLM_TIMEOUT_SECONDS=300
